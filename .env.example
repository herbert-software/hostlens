# Hostlens 环境变量模板
# 复制为 .env 并填入真实值：cp .env.example .env
# .env 已被 .gitignore 忽略，.env.example 随代码提交
#
# 嵌套字段用双下划线分隔：HOSTLENS_BACKEND__API_KEY → Settings.backend.api_key
# 详细说明见 docs/ARCHITECTURE.md §9

# ===========================================================================
# 方案 A：直连 Anthropic API（默认）
# ===========================================================================
# HOSTLENS_BACKEND__TYPE=anthropic_api
# HOSTLENS_BACKEND__API_KEY=sk-ant-your-key-here
#
# HOSTLENS_AGENT__PRIMARY_MODEL=claude-opus-4-8
# HOSTLENS_AGENT__HEALTH_CHECK_MODEL=claude-haiku-4-5

# ===========================================================================
# 方案 B：OpenRouter（DeepSeek / Qwen 等第三方模型）
# 实测验证：x-api-key 认证、Anthropic tool_use schema、cache_control 全通过
# ===========================================================================
HOSTLENS_BACKEND__TYPE=anthropic_api
HOSTLENS_BACKEND__API_KEY=sk-or-v1-your-openrouter-key-here
HOSTLENS_BACKEND__BASE_URL=https://openrouter.ai/api    # SDK 自动追加 /v1/messages；勿写 .../api/v1（会双 /v1 致 400）
HOSTLENS_BACKEND__DISABLE_THINKING=false
# 非 Claude 模型必须设 false：兼容端点不支持 prompt caching，否则 cache hit rate 指标失真
HOSTLENS_BACKEND__PROMPT_CACHING=false
# OpenRouter 推荐的统计 header（非密钥）；JSON 字符串
HOSTLENS_BACKEND__EXTRA_HEADERS='{"HTTP-Referer":"https://github.com/HerbertGao/hostlens","X-OpenRouter-Title":"hostlens"}'

# OpenRouter 模型 ID 格式：provider/model-name
# DeepSeek：deepseek/deepseek-v4-pro | deepseek/deepseek-r1
# Qwen：    qwen/qwen3.7-plus | qwen/qwen-plus-latest
# Claude：  anthropic/claude-haiku-4-5（注意：部分地区受 OpenRouter 地理限制）
HOSTLENS_AGENT__PRIMARY_MODEL=deepseek/deepseek-v4-pro
HOSTLENS_AGENT__HEALTH_CHECK_MODEL=deepseek/deepseek-v4-pro

# ===========================================================================
# 方案 C：直连 DeepSeek Anthropic 兼容端点
# ===========================================================================
# HOSTLENS_BACKEND__TYPE=anthropic_api
# HOSTLENS_BACKEND__API_KEY=sk-your-deepseek-key-here
# HOSTLENS_BACKEND__BASE_URL=https://api.deepseek.com/anthropic
# HOSTLENS_BACKEND__DISABLE_THINKING=true
#
# HOSTLENS_AGENT__PRIMARY_MODEL=deepseek-chat
# HOSTLENS_AGENT__HEALTH_CHECK_MODEL=deepseek-chat

# ===========================================================================
# Agent 通用参数（三套方案共用，按需覆盖）
# ===========================================================================
# HOSTLENS_AGENT__MAX_TURNS=20
# HOSTLENS_AGENT__TOKEN_BUDGET_INPUT=100000
# HOSTLENS_AGENT__TOKEN_BUDGET_OUTPUT=30000
# HOSTLENS_AGENT__HEALTH_CHECK_TIMEOUT_SECONDS=10

# ===========================================================================
# 日志 / 运行模式
# ===========================================================================
# HOSTLENS_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
# HOSTLENS_DAEMON_MODE=false
