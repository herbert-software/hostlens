{#-
  飞书 Lark interactive card layout (spec: notifier-lark §需求 同构结构化布局).
  Isomorphic to the Telegram layout (发现优先): 抬头(非 intent) → 覆盖行 →
  发现(四元组去重 + severity 降序 + 来源) → 根因分析. 健康态「✅未发现异常」是
  发现段的空态替代(占发现槽位、非根因后的尾段);findings 为空但有 hypotheses
  时它渲染在根因分析之前. Multi-target findings section by host when
  distinct(non-None target_name) > 1 or fleet; single-host agent degrades to a
  flat list. Every dynamic value passes through `tojson` so the card body is
  valid JSON by construction.
-#}
{
  "msg_type": "interactive",
  "card": {
    "config": {"wide_screen_mode": true},
    "header": {
      "template": {{ severity | lark_header_color | tojson }},
      "title": {
        "tag": "plain_text",
        "content": {{ ("Hostlens 巡检 · " ~ report.target_name ~ " · " ~ (severity | sev_label)) | tojson }}
      }
    },
    "elements": [
      {% if report.meta %}
      {
        "tag": "div",
        "text": {
          "tag": "lark_md",
          "content": {{ ((report.meta.timestamp | fmt_time) ~ " · " ~ (report.meta.inspectors_used | coverage)) | tojson }}
        }
      },
      {% endif %}
      {% set failed = report.inspector_results | failed_checks %}
      {% if failed %}
      {
        "tag": "div",
        "text": {
          "tag": "lark_md",
          "content": {{ "**失败检查**" | tojson }}
        }
      },
      {% for target_name, label, inspectors in failed %}
      {
        "tag": "div",
        "text": {
          "tag": "lark_md",
          "content": {{ (target_name ~ " · " ~ label ~ "：" ~ (inspectors | join("、"))) | tojson }}
        }
      },
      {% endfor %}
      {% endif %}
      {% if report.findings %}
      {
        "tag": "div",
        "text": {
          "tag": "lark_md",
          "content": {{ "**发现**" | tojson }}
        }
      }
      {% set sections = report.findings | dedup | group_by_target(fleet=(report.meta is not none and report.meta.target_type == "fleet")) %}
      {% for target_name, group in sections %}
      {% if target_name is not none %}
      ,{
        "tag": "div",
        "text": {
          "tag": "lark_md",
          "content": {{ ((group | section_severity | sev_icon) ~ " **" ~ target_name ~ " · " ~ (group | section_severity | sev_label) ~ "**") | tojson }}
        }
      }
      {% elif sections | length > 1 %}
      ,{
        "tag": "div",
        "text": {
          "tag": "lark_md",
          "content": {{ "**（未标注主机）**" | tojson }}
        }
      }
      {% endif %}
      {% for f in group | sort_sev %}
      ,{
        "tag": "div",
        "text": {
          "tag": "lark_md",
          "content": {{ ((f.severity | sev_icon) ~ " " ~ f.message ~ " (" ~ f.inspector_name ~ ")") | tojson }}
        }
      }
      {% endfor %}
      {% endfor %}
      {% else %}
      {
        "tag": "div",
        "text": {
          "tag": "lark_md",
          "content": {{ "✅ 未发现异常" | tojson }}
        }
      }
      {% endif %}
      {% if report.hypotheses %}
      ,{"tag": "hr"}
      ,{
        "tag": "div",
        "text": {
          "tag": "lark_md",
          "content": {{ "**根因分析**" | tojson }}
        }
      }
      {% for h in report.hypotheses %}
      ,{
        "tag": "div",
        "text": {
          "tag": "lark_md",
          "content": {{ ("• " ~ h.description ~ " (置信度 " ~ (h.confidence | conf_label) ~ ")") | tojson }}
        }
      }
      {% for action in h.suggested_actions %}
      ,{
        "tag": "div",
        "text": {
          "tag": "lark_md",
          "content": {{ ("↳ " ~ action) | tojson }}
        }
      }
      {% endfor %}
      {% endfor %}
      {% endif %}
    ]
  }
}
